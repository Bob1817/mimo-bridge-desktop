{
  "name": "mimo-bridge-desktop",
  "version": "3.0.0",
  "description": "AI Coding Gateway - Claude Code / Cursor / Codex Universal Proxy",
  "author": "Bob1817",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bob1817/mimo-bridge-desktop.git"
  },
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:main && concurrently \"cd renderer && npm run dev\" \"tsc -w\" \"sleep 2 && electron dist/main.js\"",
    "build": "npm run build:main && npm run build:renderer && npm run build:electron",
    "build:main": "tsc",
    "build:renderer": "cd renderer && npm run build",
    "build:electron": "electron-builder",
    "start": "electron dist/main.js",
    "server": "node dist/gateway/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron-updater": "^6.3.9",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "electron": "^30.0.9",
    "electron-builder": "^25.1.8",
    "typescript": "^5.4.0"
  },
  "build": {
    "appId": "com.mimo.ai-gateway",
    "productName": "MIMO Gateway",
    "publish": {
      "provider": "github",
      "owner": "Bob1817",
      "repo": "mimo-bridge-desktop"
    },
    "mac": { "target": ["dmg", "zip"] },
    "win": { "target": ["nsis"] },
    "linux": { "target": ["AppImage"] },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true },
    "files": [
      "dist/**/*",
      "package.json"
    ]
  },
  "engines": { "node": ">=18" }
}
